# =============================================================================
# DerivArena — root environment (copy to `.env` at the repo root)
# =============================================================================
# Never commit a real `.env` file. Only this template is versioned.
#
# Database URL must be the same Postgres instance you:
#   - migrate/seed with `make db-migrate` (loads this file via scripts/load-db-env.sh)
#   - expose to the Next.js server as DATABASE_URL in frontend/.env.local when using
#     Trading Copilot entitlements (Postgres `deriv_trading_copilot_entitlements`).
#
# Makefile defaults to localhost:5432; Docker/Colima examples often use 5436.
# Pick one host/port and use it everywhere.
# =============================================================================

DATABASE_URL=postgresql://derivarena:derivarena@localhost:5436/derivarena

# Go API (make backend, scripts/dev.sh when starting API outside Makefile)
PORT=8090
BASE_URL=http://localhost:8090

# Browser → Go API (also referenced from root for some scripts/docs)
NEXT_PUBLIC_API_URL=http://localhost:8090

# Deriv API / OAuth (optional unless you use live OAuth flows)
DERIV_APP_ID=
DERIV_ACCESS_TOKEN=
DERIV_ACCOUNT_ID=

# JWT secret for signing httpOnly `arena_session` cookies (use a long random value in production)
JWT_SECRET=

# Optional: base URL for share links generated by the backend
# SHARE_BASE_URL=http://localhost:3000

# Telegram broadcast bot (posts to @DerivArenaAsk)
# Leave TELEGRAM_ENABLED=false in local dev; set TELEGRAM_DRY_RUN=true to log only
TELEGRAM_ENABLED=false
TELEGRAM_DRY_RUN=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=@DerivArenaAsk
TELEGRAM_MAX_POSTS_PER_HOUR=8
TELEGRAM_BIG_WIN_MIN_PNL=100

# Admin API key (32+ random bytes, used for /api/admin/telegram/*)
ADMIN_API_KEY=

# @vercel/og base (usually the public frontend URL)
OG_BASE_URL=https://frontend-preethi-3498s-projects.vercel.app
FRONTEND_BASE_URL=https://frontend-preethi-3498s-projects.vercel.app
INTERNAL_API_URL=http://localhost:8090
