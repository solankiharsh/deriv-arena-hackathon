# Same Postgres as repo root `DATABASE_URL` / `make db-migrate` (entitlements + miles).
# If unset here, some server routes skip DB work — set explicitly for Trading Copilot.
DATABASE_URL=postgresql://derivarena:derivarena@localhost:5436/derivarena

NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_DERIV_APP_ID=
# Partner tracking (see root .env.example for the full explanation)
# Leave NEXT_PUBLIC_PARTNER_TRACKING_URL blank/unset so game-invite clicks
# route back into this app via /click. Only set it when you want an invite
# click to be handled by Deriv's external affiliate tracker.
NEXT_PUBLIC_PARTNER_TRACKING_URL=
NEXT_PUBLIC_PARTNER_TRACKING_COMMISSION_PLAN_ID=3
NEXT_PUBLIC_PARTNER_TRACKING_LINK_ID=1
DERIV_APP_ID=
DERIV_ACCESS_TOKEN=
# Required for Trading Copilot chat (OpenAI). Restart `npm run dev` after setting.
OPENAI_API_KEY=
# Optional override (default: gpt-4o-mini)
# TRADING_COPILOT_MODEL=gpt-4o-mini
PRIVY_APP_ID=
PRIVY_APP_SECRET=
NEXT_PUBLIC_PRIVY_APP_ID=
JWT_SECRET=
ADMIN_DERIV_IDS=
MIGRATION_SECRET=

# Telegram channel URL surfaced in navbar CTA (public, hardcoded target)
NEXT_PUBLIC_TELEGRAM_CHANNEL_URL=https://t.me/DerivArenaAsk

# Server-only: used by OG routes to fetch data from the Go API
INTERNAL_API_URL=http://localhost:8090
